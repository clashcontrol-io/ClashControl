{
  "name": "@clashcontrol/mcp-server",
  "version": "0.1.0",
  "description": "ClashControl Smart Bridge — LLM bridge connecting Claude, ChatGPT, or any AI assistant to BIM clash detection",
  "main": "index.js",
  "bin": {
    "clashcontrol-mcp": "./index.js",
    "clashcontrol-rest": "./rest-bridge.js"
  },
  "scripts": {
    "start": "node index.js",
    "rest": "node rest-bridge.js",
    "both": "node index.js & node rest-bridge.js",
    "bundle": "npx pkg rest-bridge.js --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --output dist/clashcontrol-smart-bridge"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.0"
  },
  "license": "MIT"
}
