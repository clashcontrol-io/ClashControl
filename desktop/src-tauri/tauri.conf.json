{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClashControl",
  "version": "0.1.0",
  "identifier": "io.clashcontrol.desktop",
  "build": {
    "frontendDist": "../../dist",
    "beforeBuildCommand": "bash desktop/build-dist.sh || bash ../build-dist.sh"
  },
  "app": {
    "windows": [
      {
        "title": "ClashControl",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}